"---\nimport '../styles/global.css';\nimport { copy } from '../content/copy';\n\ninterface Props {\n  title: string;\n  description?: string;\n}\n\nconst { title, description = copy.meta.defaultDescription } = Astro.props;\nconst copyJson = JSON.stringify(copy);\n---\n\n<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <meta name=\"description\" content={description} />\n    <link rel=\"icon\" type=\"image/svg+xml\" href=\"/favicon.svg\" />\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=DM+Sans:wght@700;800&family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n    <meta name=\"generator\" content={Astro.generator} />\n    \n    <!-- Open Graph -->\n    <meta property=\"og:title\" content={title} />\n    <meta property=\"og:description\" content={description} />\n    <meta property=\"og:type\" content=\"website\" />\n    <meta property=\"og:url\" content=\"https://magmalink.com\" />\n    \n    <!-- Twitter -->\n    <meta name=\"twitter:card\" content=\"summary_large_image\" />\n    <meta name=\"twitter:title\" content={title} />\n    <meta name=\"twitter:description\" content={description} />\n    \n    <title>{title}</title>\n  </head>\n  <body class=\"min-h-screen flex flex-col bg-offwhite\">\n    <header class=\"sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-slate-200/80\">\n      <nav class=\"max-w-6xl mx-auto px-6 py-4 flex items-center justify-between\">\n        <a href=\"/\" class=\"flex items-center gap-2 group\">\n          <div class=\"w-8 h-8 bg-navy rounded-lg flex items-center justify-center\">\n            <span class=\"text-accent font-bold text-sm\">M</span>\n          </div>\n          <span class=\"text-xl font-bold text-navy group-hover:text-accent transition-colors\" data-copy-key=\"siteName\">{copy.siteName}</span>\n        </a>\n        \n        <!-- Desktop Navigation -->\n        <div class=\"hidden md:flex items-center gap-6\">\n          <a href=\"/#services\" class=\"text-[#475569] hover:text-[#0F172A] transition-colors font-medium\" data-copy-key=\"nav.services\">{copy.nav.services}</a>\n          <a href=\"/#how-we-work\" class=\"text-[#475569] hover:text-[#0F172A] transition-colors font-medium\" data-copy-key=\"nav.howWeWork\">{copy.nav.howWeWork}</a>\n          <a href=\"/#why-us\" class=\"text-[#475569] hover:text-[#0F172A] transition-colors font-medium\" data-copy-key=\"nav.whyUs\">{copy.nav.whyUs}</a>\n          <a href=\"/#faq\" class=\"text-[#475569] hover:text-[#0F172A] transition-colors font-medium\" data-copy-key=\"nav.faq\">{copy.nav.faq}</a>\n          <a href=\"/contact\" class=\"bg-accent text-white px-5 py-2.5 rounded-lg font-medium hover:bg-accent-hover transition-colors shadow-sm shadow-accent/20\" data-copy-key=\"nav.getInTouch\">{copy.nav.getInTouch}</a>\n        </div>\n\n        <!-- Mobile Menu Button -->\n        <button \n          id=\"mobile-menu-btn\"\n          class=\"md:hidden p-2 text-[#475569] hover:text-[#0F172A] transition-colors\"\n          aria-label=\"Toggle menu\"\n        >\n          <svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path id=\"menu-icon\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 6h16M4 12h16M4 18h16\"/>\n          </svg>\n        </button>\n      </nav>\n\n      <!-- Mobile Navigation -->\n      <div id=\"mobile-menu\" class=\"hidden md:hidden border-t border-slate-200 bg-white\">\n        <div class=\"px-6 py-4 space-y-4\">\n          <a href=\"/#services\" class=\"block text-[#475569] hover:text-[#0F172A] transition-colors font-medium py-2\" data-copy-key=\"nav.services\">{copy.nav.services}</a>\n          <a href=\"/#how-we-work\" class=\"block text-[#475569] hover:text-[#0F172A] transition-colors font-medium py-2\" data-copy-key=\"nav.howWeWork\">{copy.nav.howWeWork}</a>\n          <a href=\"/#why-us\" class=\"block text-[#475569] hover:text-[#0F172A] transition-colors font-medium py-2\" data-copy-key=\"nav.whyUs\">{copy.nav.whyUs}</a>\n          <a href=\"/#faq\" class=\"block text-[#475569] hover:text-[#0F172A] transition-colors font-medium py-2\" data-copy-key=\"nav.faq\">{copy.nav.faq}</a>\n          <a href=\"/contact\" class=\"block bg-accent text-white px-5 py-3 rounded-lg font-medium hover:bg-accent-hover transition-colors text-center\" data-copy-key=\"nav.getInTouch\">{copy.nav.getInTouch}</a>\n        </div>\n      </div>\n    </header>\n\n    <main class=\"flex-grow\">\n      <slot />\n    </main>\n\n    <footer class=\"bg-[#0F172A] text-white py-16\">\n      <div class=\"max-w-6xl mx-auto px-6\">\n        <div class=\"grid md:grid-cols-4 gap-8 mb-12\">\n          <div class=\"md:col-span-2\">\n            <div class=\"flex items-center gap-2 mb-4\">\n              <div class=\"w-8 h-8 bg-accent rounded-lg flex items-center justify-center\">\n                <span class=\"text-white font-bold text-sm\">M</span>\n              </div>\n              <span class=\"text-xl font-bold\" data-copy-key=\"siteName\">{copy.siteName}</span>\n            </div>\n            <p class=\"text-slate-400 mb-6 max-w-sm\">\n              <span data-copy-key=\"footer.tagline\">{copy.footer.tagline}</span>\n            </p>\n            <p class=\"text-slate-500 text-sm\">\n              <span data-copy-key=\"footer.location\">{copy.footer.location}</span>\n            </p>\n          </div>\n          <div>\n            <h4 class=\"font-semibold mb-4 text-white\" data-copy-key=\"footer.quickLinks\">{copy.footer.quickLinks}</h4>\n            <ul class=\"space-y-3 text-slate-400\">\n              <li><a href=\"/#services\" class=\"hover:text-white transition-colors\" data-copy-key=\"nav.services\">{copy.nav.services}</a></li>\n              <li><a href=\"/#how-we-work\" class=\"hover:text-white transition-colors\" data-copy-key=\"nav.howWeWork\">{copy.nav.howWeWork}</a></li>\n              <li><a href=\"/#faq\" class=\"hover:text-white transition-colors\" data-copy-key=\"nav.faq\">{copy.nav.faq}</a></li>\n              <li><a href=\"/#why-us\" class=\"hover:text-white transition-colors\" data-copy-key=\"nav.whyUs\">{copy.nav.whyUs}</a></li>\n              <li><a href=\"/contact\" class=\"hover:text-white transition-colors\" data-copy-key=\"footer.contact\">{copy.footer.contact}</a></li>\n            </ul>\n          </div>\n          <div>\n            <h4 class=\"font-semibold mb-4 text-white\" data-copy-key=\"footer.legal\">{copy.footer.legal}</h4>\n            <ul class=\"space-y-3 text-slate-400\">\n              <li><a href=\"/privacy\" class=\"hover:text-white transition-colors\" data-copy-key=\"footer.privacy\">{copy.footer.privacy}</a></li>\n              <li><a href=\"/terms\" class=\"hover:text-white transition-colors\" data-copy-key=\"footer.terms\">{copy.footer.terms}</a></li>\n            </ul>\n          </div>\n        </div>\n        <div class=\"border-t border-slate-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-4\">\n          <p class=\"text-slate-500 text-sm\">\n            &copy; {new Date().getFullYear()} <span data-copy-key=\"siteName\">{copy.siteName}</span>. <span data-copy-key=\"footer.copyright\">{copy.footer.copyright}</span>\n          </p>\n          <a href={`mailto:${copy.email}`} class=\"text-slate-400 hover:text-accent transition-colors text-sm\" data-copy-key=\"email\">{copy.email}</a>\n        </div>\n      </div>\n    </footer>\n\n    <script>\n      // Mobile menu toggle\n      const menuBtn = document.getElementById('mobile-menu-btn');\n      const mobileMenu = document.getElementById('mobile-menu');\n      const menuIcon = document.getElementById('menu-icon');\n      \n      menuBtn?.addEventListener('click', () => {\n        const isHidden = mobileMenu?.classList.contains('hidden');\n        mobileMenu?.classList.toggle('hidden');\n        \n        // Toggle icon between hamburger and X\n        if (isHidden) {\n          menuIcon?.setAttribute('d', 'M6 18L18 6M6 6l12 12');\n        } else {\n          menuIcon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');\n        }\n      });\n\n      // Close mobile menu when clicking a link\n      mobileMenu?.querySelectorAll('a').forEach(link => {\n        link.addEventListener('click', () => {\n          mobileMenu.classList.add('hidden');\n          menuIcon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');\n        });\n      });\n    </script>\n\n    <!-- Edit mode: ?edit=1 makes copy editable; Save stores to localStorage and downloads copy-edits.json -->\n    <script is:inline set:html={`window.__COPY__ = ${copyJson};`} />\n    <script is:inline src=\"/edit-mode.js\"></script>\n  </body>\n</html>\n"