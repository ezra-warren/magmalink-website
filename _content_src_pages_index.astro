"---\nimport Layout from '../layouts/Layout.astro';\nimport { copy } from '../content/copy';\n---\n\n<Layout title={`${copy.siteName} - Outreach. Simplified.`} description={copy.meta.defaultDescription}>\n  <!-- Hero Section - Dark gradient like The Deal Lab / Engineered GTM -->\n  <section class=\"relative bg-gradient-to-br from-[#0F172A] via-[#1E293B] to-[#0F172A] py-20 md:py-28 overflow-hidden\">\n    <!-- Decorative elements -->\n    <div class=\"absolute inset-0 opacity-10\">\n      <!-- dot-grid colour = accent. Update rgba to match --color-accent when rebranding -->\n      <div class=\"absolute inset-0\" style=\"background-image: radial-gradient(circle at 2px 2px, rgba(59,130,246,0.3) 1px, transparent 0); background-size: 32px 32px;\"></div>\n    </div>\n    <div class=\"absolute top-20 right-10 w-72 h-72 bg-accent rounded-full blur-[120px] opacity-20\"></div>\n    <div class=\"absolute bottom-10 left-10 w-96 h-96 bg-[#F59E0B] rounded-full blur-[150px] opacity-10\"></div>\n    \n    <div class=\"relative max-w-6xl mx-auto px-6\">\n      <!-- Tools strip -->\n      <div class=\"flex justify-center mb-10\">\n        <div class=\"flex items-center gap-3 bg-white/5 border border-white/10 rounded-full px-6 py-2.5\">\n          {copy.hero.tools.map((name, i) => (\n            <>\n              {i > 0 && <span class=\"text-white/30\">\u2022</span>}\n              <span class=\"text-white/60 text-sm font-medium\">{name}</span>\n            </>\n          ))}\n        </div>\n      </div>\n\n      <div class=\"text-center max-w-4xl mx-auto\">\n        <h1 class=\"text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight text-center\">\n          <span data-copy-key=\"hero.headlineLine1\">{copy.hero.headlineLine1}</span>\n        </h1>\n        <p class=\"text-xl md:text-2xl text-slate-300 mb-8 leading-relaxed max-w-3xl mx-auto text-center\">\n          <span data-copy-key=\"hero.subheadline\">{copy.hero.subheadline}</span>\n        </p>\n        \n        <!-- Outcome bullets (stacked vertically) -->\n        <div class=\"flex flex-col items-center gap-3 mb-10 text-slate-400\">\n          <div class=\"flex items-center gap-2\">\n            <svg class=\"w-5 h-5 text-[#10B981] flex-shrink-0\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"/></svg>\n            <span data-copy-key=\"hero.bullet1\">{copy.hero.bullet1}</span>\n          </div>\n          <div class=\"flex items-center gap-2\">\n            <svg class=\"w-5 h-5 text-[#10B981] flex-shrink-0\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"/></svg>\n            <span data-copy-key=\"hero.bullet2\">{copy.hero.bullet2}</span>\n          </div>\n          <div class=\"flex items-center gap-2\">\n            <svg class=\"w-5 h-5 text-[#10B981] flex-shrink-0\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"/></svg>\n            <span data-copy-key=\"hero.bullet3\">{copy.hero.bullet3}</span>\n          </div>\n        </div>\n\n        <div class=\"flex flex-col sm:flex-row gap-4 justify-center\">\n          <a \n            href=\"/contact\" \n            class=\"inline-flex items-center justify-center bg-accent text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-accent-hover transition-all hover:scale-105 shadow-lg shadow-accent/25\"\n            data-copy-key=\"hero.ctaPrimary\"\n          >\n            {copy.hero.ctaPrimary}\n            <svg class=\"ml-2 w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M17 8l4 4m0 0l-4 4m4-4H3\"/>\n            </svg>\n          </a>\n          <a \n            href=\"#how-we-work\" \n            class=\"inline-flex items-center justify-center bg-white/10 backdrop-blur-sm text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-white/20 transition-all border border-white/20\"\n            data-copy-key=\"hero.ctaSecondary\"\n          >\n            {copy.hero.ctaSecondary}\n          </a>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Services Section -->\n  <section id=\"services\" class=\"py-20 bg-white\">\n    <div class=\"max-w-6xl mx-auto px-6\">\n      <div class=\"text-center mb-10\">\n        <span class=\"inline-block text-accent font-semibold text-sm uppercase tracking-wider mb-3\" data-copy-key=\"services.label\">{copy.services.label}</span>\n        <h2 class=\"text-3xl md:text-4xl font-bold text-[#0F172A] mb-4\">\n          <span data-copy-key=\"services.title\">{copy.services.title}</span>\n        </h2>\n        <p class=\"text-lg text-[#475569] max-w-2xl mx-auto\">\n          <span data-copy-key=\"services.subtitle\">{copy.services.subtitle}</span>\n        </p>\n      </div>\n\n      <div class=\"grid md:grid-cols-2 gap-6 lg:gap-8\">\n        {\n          [\n            { key: 'outboundEngine', section: copy.services.outboundEngine, color: '#3B82F6' /* brand accent \u2014 match --color-accent in global.css */, icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },\n            { key: 'outboundMultiChannel', section: copy.services.outboundMultiChannel, color: '#F59E0B', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z' },\n            { key: 'revOpsWorkflow', section: copy.services.revOpsWorkflow, color: '#10B981', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },\n            { key: 'aiEnablement', section: copy.services.aiEnablement, color: '#8B5CF6', icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z' },\n          ].map(({ key, section, color, icon }) => (\n            <div class=\"group relative p-6 lg:p-8 rounded-2xl shadow-md hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 cursor-pointer overflow-hidden\" style={`background: linear-gradient(135deg, ${color}06, ${color}12);`}>\n              {/* Left border - thickens on hover */}\n              <div class=\"absolute left-0 top-0 bottom-0 w-1 group-hover:w-1.5 transition-all duration-300\" style={`background: ${color};`}></div>\n              {/* Hover overlay */}\n              <div class=\"absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300\" style={`background: linear-gradient(135deg, ${color}10, ${color}18);`}></div>\n              \n              <div class=\"relative z-10\">\n                {/* Icon + Title row */}\n                <div class=\"flex items-center gap-4 mb-5\">\n                  <div class=\"w-12 h-12 rounded-xl flex items-center justify-center shadow-md group-hover:shadow-lg group-hover:scale-105 transition-all duration-300 flex-shrink-0\" style={`background: linear-gradient(135deg, ${color}, ${color}dd);`}>\n                    <svg class=\"w-6 h-6 text-white\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d={icon}/>\n                    </svg>\n                  </div>\n                  <h3 class=\"text-xl lg:text-2xl font-bold text-[#0F172A]\" data-copy-key={`services.${key}.title`}>{section.title}</h3>\n                </div>\n                {/* Bullets */}\n                <ul class=\"space-y-3 pl-1\">\n                  {section.bullets.map((bullet, i) => (\n                    <li class=\"flex items-start gap-3\">\n                      <svg class=\"w-5 h-5 flex-shrink-0 mt-0.5\" style={`color: ${color}`} fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"/></svg>\n                      <span class=\"text-[#475569] text-base leading-relaxed\" data-copy-key={`services.${key}.bullets.${i}`}>{bullet}</span>\n                    </li>\n                  ))}\n                </ul>\n              </div>\n            </div>\n          ))\n        }\n      </div>\n    </div>\n  </section>\n\n  <!-- How We Work - Expandable Accordion -->\n  <section id=\"how-we-work\" class=\"py-20 bg-gradient-to-b from-offwhite to-white\">\n    <div class=\"max-w-4xl mx-auto px-6\">\n      <div class=\"text-center mb-16\">\n        <span class=\"inline-block text-accent font-semibold text-sm uppercase tracking-wider mb-3\" data-copy-key=\"howWeWork.label\">{copy.howWeWork.label}</span>\n        <h2 class=\"text-3xl md:text-4xl font-bold text-[#0F172A] mb-4\">\n          <span data-copy-key=\"howWeWork.title\">{copy.howWeWork.title}</span>\n        </h2>\n      </div>\n\n      <div class=\"flex flex-col gap-4\" id=\"hww-accordion\">\n        {\n          [\n            /* 1. Discovery & Strategy - Bold crosshair/target */\n            { color: '#3B82F6' /* brand accent \u2014 match --color-accent in global.css */, icon: `<circle cx=\"12\" cy=\"12\" r=\"8\" stroke=\"white\" stroke-width=\"2\" fill=\"none\"/><circle cx=\"12\" cy=\"12\" r=\"3.5\" stroke=\"white\" stroke-width=\"2\" fill=\"white\" fill-opacity=\"0.3\"/><line x1=\"12\" y1=\"1\" x2=\"12\" y2=\"5.5\" stroke=\"white\" stroke-width=\"2\" stroke-linecap=\"round\"/><line x1=\"12\" y1=\"18.5\" x2=\"12\" y2=\"23\" stroke=\"white\" stroke-width=\"2\" stroke-linecap=\"round\"/><line x1=\"1\" y1=\"12\" x2=\"5.5\" y2=\"12\" stroke=\"white\" stroke-width=\"2\" stroke-linecap=\"round\"/><line x1=\"18.5\" y1=\"12\" x2=\"23\" y2=\"12\" stroke=\"white\" stroke-width=\"2\" stroke-linecap=\"round\"/>` },\n            /* 2. Infrastructure Setup - Bold cog */\n            { color: '#6366F1', icon: `<path d=\"M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z\" stroke=\"white\" stroke-width=\"1.5\" fill=\"none\" stroke-linejoin=\"round\"/><circle cx=\"12\" cy=\"12\" r=\"3\" stroke=\"white\" stroke-width=\"1.5\" fill=\"white\" fill-opacity=\"0.3\"/>` },\n            /* 3. List Building & Enrichment - Three lines converging to bullseye */\n            { color: '#8B5CF6', icon: `<circle cx=\"19\" cy=\"12\" r=\"3.5\" stroke=\"white\" stroke-width=\"2\" fill=\"white\" fill-opacity=\"0.3\"/><circle cx=\"19\" cy=\"12\" r=\"1\" fill=\"white\"/><path d=\"M2 5h5l6 5\" stroke=\"white\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M2 12h10\" stroke=\"white\" stroke-width=\"2\" stroke-linecap=\"round\"/><path d=\"M2 19h5l6-5\" stroke=\"white\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><circle cx=\"2\" cy=\"5\" r=\"1.5\" fill=\"white\"/><circle cx=\"2\" cy=\"12\" r=\"1.5\" fill=\"white\"/><circle cx=\"2\" cy=\"19\" r=\"1.5\" fill=\"white\"/>` },\n            /* 4. Messaging & Campaign Launch - Bold envelope */\n            { color: '#F59E0B', icon: `<rect x=\"2\" y=\"5\" width=\"20\" height=\"14\" rx=\"2\" stroke=\"white\" stroke-width=\"2\" fill=\"white\" fill-opacity=\"0.15\"/><path d=\"M2 7l10 7 10-7\" stroke=\"white\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>` },\n            /* 5. Lead Routing & Optimisation - Bold funnel */\n            { color: '#10B981', icon: `<path d=\"M2 7h20l-7 8v5l-6 3V15L2 7z\" stroke=\"white\" stroke-width=\"2\" fill=\"white\" fill-opacity=\"0.15\" stroke-linejoin=\"round\"/><circle cx=\"6\" cy=\"3\" r=\"1.5\" fill=\"white\" opacity=\"0.8\"/><circle cx=\"12\" cy=\"3\" r=\"1.5\" fill=\"white\" opacity=\"0.8\"/><circle cx=\"18\" cy=\"3\" r=\"1.5\" fill=\"white\" opacity=\"0.8\"/>` },\n            /* 6. Iterate & Scale - Bar chart trending up */\n            { color: '#0F172A', icon: `<rect x=\"3\" y=\"14\" width=\"4\" height=\"7\" rx=\"1\" fill=\"white\" opacity=\"0.5\"/><rect x=\"10\" y=\"10\" width=\"4\" height=\"11\" rx=\"1\" fill=\"white\" opacity=\"0.7\"/><rect x=\"17\" y=\"5\" width=\"4\" height=\"16\" rx=\"1\" fill=\"white\"/><line x1=\"2\" y1=\"22\" x2=\"22\" y2=\"22\" stroke=\"white\" stroke-width=\"2\" stroke-linecap=\"round\"/>` },\n          ].map(({ color, icon }, i) => {\n            const step = copy.howWeWork.steps[i];\n            return (\n              <div\n                class=\"group relative rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 cursor-pointer hww-tile\"\n                style={`background: linear-gradient(135deg, ${color}06, ${color}10); border: 1px solid ${color}20;`}\n                data-hww-index={i}\n              >\n                {/* Left accent bar */}\n                <div class=\"absolute left-0 top-0 bottom-0 w-1 transition-all duration-300 hww-bar\" style={`background: ${color};`}></div>\n\n                {/* Header (always visible, clickable) */}\n                <button\n                  class=\"w-full flex items-center gap-4 p-5 lg:p-6 text-left hww-toggle\"\n                  type=\"button\"\n                  aria-expanded=\"false\"\n                >\n                  <div\n                    class=\"w-14 h-14 rounded-xl flex items-center justify-center text-white font-bold text-xl flex-shrink-0 shadow-md\"\n                    style={`background: linear-gradient(135deg, ${color}, ${color}cc);`}\n                  >{i + 1}</div>\n                  <h3 class=\"text-lg lg:text-xl font-bold text-[#0F172A] flex-1\" data-copy-key={`howWeWork.steps.${i}.title`}>{step.title}</h3>\n                  {/* Illustration on the collapsed header */}\n                  <div class=\"hidden md:flex items-center justify-center flex-shrink-0\">\n                    <div class=\"w-14 h-14 rounded-xl flex items-center justify-center shadow-md group-hover:shadow-lg group-hover:scale-105 transition-all duration-300\" style={`background: linear-gradient(135deg, ${color}, ${color}dd);`}>\n                      <svg class=\"w-9 h-9\" viewBox=\"0 0 24 24\" fill=\"none\" set:html={icon}/>\n                    </div>\n                  </div>\n                  <svg class=\"w-5 h-5 text-slate-400 flex-shrink-0 transition-transform duration-300 hww-chevron\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\"/>\n                  </svg>\n                </button>\n\n                {/* Expandable content */}\n                <div class=\"hww-content overflow-hidden transition-all duration-300\" style=\"max-height: 0; opacity: 0;\">\n                  <div class=\"px-5 lg:px-6 pb-6 pl-[4.75rem] pr-5 lg:pr-8\">\n                    <ul class=\"space-y-2 mb-4\">\n                      {step.bullets.map((bullet, bi) => (\n                        <li class=\"flex items-start gap-3\">\n                          <svg class=\"w-4 h-4 flex-shrink-0 mt-1\" style={`color: ${color}`} fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"/></svg>\n                          <span class=\"text-[#475569] text-base leading-relaxed\" data-copy-key={`howWeWork.steps.${i}.bullets.${bi}`}>{bullet}</span>\n                        </li>\n                      ))}\n                    </ul>\n                    <div class=\"flex items-start gap-2 pt-3 border-t border-slate-200/60\">\n                      <span class=\"text-xs font-semibold uppercase tracking-wider flex-shrink-0 mt-0.5\" style={`color: ${color};`}>Outcome</span>\n                      <span class=\"text-[#0F172A] font-medium text-sm leading-relaxed\" data-copy-key={`howWeWork.steps.${i}.outcome`}>{step.outcome}</span>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            );\n          })\n        }\n      </div>\n    </div>\n  </section>\n\n  <script>\n    document.addEventListener('DOMContentLoaded', () => {\n      const accordion = document.getElementById('hww-accordion');\n      if (!accordion) return;\n\n      accordion.querySelectorAll('.hww-tile').forEach(tile => {\n        const toggle = tile.querySelector('.hww-toggle');\n        const content = tile.querySelector('.hww-content') as HTMLElement;\n        const chevron = tile.querySelector('.hww-chevron');\n        const bar = tile.querySelector('.hww-bar') as HTMLElement;\n        if (!toggle || !content || !chevron || !bar) return;\n\n        toggle.addEventListener('click', () => {\n          const isOpen = toggle.getAttribute('aria-expanded') === 'true';\n          if (isOpen) {\n            toggle.setAttribute('aria-expanded', 'false');\n            content.style.maxHeight = '0';\n            content.style.opacity = '0';\n            chevron.classList.remove('rotate-180');\n            bar.style.width = '4px';\n          } else {\n            toggle.setAttribute('aria-expanded', 'true');\n            content.style.maxHeight = content.scrollHeight + 'px';\n            content.style.opacity = '1';\n            chevron.classList.add('rotate-180');\n            bar.style.width = '6px';\n          }\n        });\n      });\n    });\n  </script>\n\n  <!-- Us vs. Others - Like The Deal Lab / Engineered GTM -->\n  <section id=\"why-us\" class=\"py-20 bg-white\">\n    <div class=\"max-w-5xl mx-auto px-6\">\n      <div class=\"text-center mb-12\">\n        <span class=\"inline-block text-accent font-semibold text-sm uppercase tracking-wider mb-3\" data-copy-key=\"whyUs.label\">{copy.whyUs.label}</span>\n        <h2 class=\"text-3xl md:text-4xl font-bold text-[#0F172A]\">\n          <span data-copy-key=\"whyUs.title\">{copy.whyUs.title}</span>\n        </h2>\n      </div>\n\n      <div class=\"grid md:grid-cols-2 gap-8\">\n        <div class=\"bg-gradient-to-br from-accent-subtle to-white p-8 rounded-2xl border-2 border-[#F97316]/30\">\n          <div class=\"flex items-center gap-3 mb-6\">\n            <div class=\"w-10 h-10 bg-accent rounded-lg flex items-center justify-center shadow-sm\">\n              <span class=\"text-white font-bold\">M</span>\n            </div>\n            <span class=\"font-bold text-[#0F172A] text-xl\" data-copy-key=\"whyUs.us.title\">{copy.whyUs.us.title}</span>\n          </div>\n          <ul class=\"space-y-4\">\n            <li class=\"flex items-start gap-3\">\n              <svg class=\"w-5 h-5 text-[#10B981] flex-shrink-0 mt-0.5\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"/></svg>\n              <span class=\"text-[#475569]\" data-copy-key=\"whyUs.us.item1\">{copy.whyUs.us.item1}</span>\n            </li>\n            <li class=\"flex items-start gap-3\">\n              <svg class=\"w-5 h-5 text-[#10B981] flex-shrink-0 mt-0.5\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"/></svg>\n              <span class=\"text-[#475569]\" data-copy-key=\"whyUs.us.item2\">{copy.whyUs.us.item2}</span>\n            </li>\n            <li class=\"flex items-start gap-3\">\n              <svg class=\"w-5 h-5 text-[#10B981] flex-shrink-0 mt-0.5\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"/></svg>\n              <span class=\"text-[#475569]\" data-copy-key=\"whyUs.us.item3\">{copy.whyUs.us.item3}</span>\n            </li>\n            <li class=\"flex items-start gap-3\">\n              <svg class=\"w-5 h-5 text-[#10B981] flex-shrink-0 mt-0.5\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"/></svg>\n              <span class=\"text-[#475569]\" data-copy-key=\"whyUs.us.item4\">{copy.whyUs.us.item4}</span>\n            </li>\n          </ul>\n        </div>\n\n        <div class=\"bg-slate-50 p-8 rounded-2xl border border-slate-200\">\n          <div class=\"flex items-center gap-3 mb-6\">\n            <div class=\"w-10 h-10 bg-slate-300 rounded-lg flex items-center justify-center\">\n              <span class=\"text-slate-500 font-bold\">?</span>\n            </div>\n            <span class=\"font-bold text-slate-400 text-xl\" data-copy-key=\"whyUs.them.title\">{copy.whyUs.them.title}</span>\n          </div>\n          <ul class=\"space-y-4\">\n            <li class=\"flex items-start g